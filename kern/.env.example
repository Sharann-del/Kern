VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GitHub OAuth (live source) — register this exact callback on the GitHub OAuth app (must match origin):
#   http://localhost:5173/oauth/callback/github   (local)
#   https://your-domain/oauth/callback/github      (production)
VITE_GITHUB_CLIENT_ID=

# Google Calendar OAuth (live source) — add this redirect URI in Google Cloud Console (OAuth client):
#   http://localhost:5173/oauth/callback/google   (local)
#   https://your-domain/oauth/callback/google      (production)
VITE_GOOGLE_CLIENT_ID=

# Edge Functions — same API URL as VITE_SUPABASE_URL.
SUPABASE_URL=
# Local `functions serve --env-file`: either name works.
# Hosted: set via CLI/dashboard as SERVICE_ROLE_KEY only (`supabase secrets set` rejects SUPABASE_*).
SUPABASE_SERVICE_ROLE_KEY=
SERVICE_ROLE_KEY=

# Edge Functions: GitHub live source + token encryption.
# Hosted: set in Supabase Dashboard → Project Settings → Edge Functions → Secrets (names must match):
#   ENCRYPTION_KEY       — 64 hex chars (32 bytes), e.g. openssl rand -hex 32
#   GITHUB_CLIENT_ID     — same as VITE_GITHUB_CLIENT_ID / your GitHub OAuth app Client ID
#   GITHUB_CLIENT_SECRET — from the same GitHub OAuth app (server-only; never VITE_*)
#   GOOGLE_CLIENT_ID     — same as VITE_GOOGLE_CLIENT_ID (Calendar OAuth client)
#   GOOGLE_CLIENT_SECRET — server-only; from the same Google OAuth client
# SUPABASE_URL + SUPABASE_ANON_KEY are normally auto-injected on hosted; add manually only if a deploy lists them missing.
# CLI: supabase secrets set ENCRYPTION_KEY=... GITHUB_CLIENT_ID=... GITHUB_CLIENT_SECRET=...
ENCRYPTION_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Edge Functions runtime (required for `supabase functions serve`) ---
# Copy VITE_* URL/key here so the CLI can inject them into the function process:
# SUPABASE_URL=<same as VITE_SUPABASE_URL>
# SUPABASE_ANON_KEY=<same as VITE_SUPABASE_ANON_KEY>
# If the app shows "Failed to send a request to the Edge Function", the browser cannot
# reach {VITE_SUPABASE_URL}/functions/v1/…. Fix:
#   Local: from kern/, run `supabase functions serve --env-file .env.local` (include vars above + secrets).
#   Hosted: deploy sync-github, oauth-callback-github, sync-google-calendar, oauth-callback-google, sync-rss, test-rss-feed.

# Local MCP bridge (Cursor): set in MCP config env, not here, unless you export for testing:
# KERN_MCP_URL=https://YOUR_REF.supabase.co/functions/v1/kern-mcp
# KERN_SUPABASE_ANON_KEY=<same as VITE_SUPABASE_ANON_KEY>
# KERN_ACCESS_TOKEN=<Settings → Generate token>
