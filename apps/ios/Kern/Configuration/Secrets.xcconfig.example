// 1. Copy to: Configuration/Secrets.xcconfig (gitignored)
// 2. From apps/web/.env.local: VITE_SUPABASE_URL → SUPABASE_URL, VITE_SUPABASE_ANON_KEY → SUPABASE_ANON_KEY
// 3. URL line: use https:/$()/your-ref.supabase.co — .xcconfig treats // as EOL comment (even in quotes), so plain https:// is truncated.
// 4. Product → Clean Build Folder, then run.
// 5. Supabase Auth redirects: kern://auth-callback

SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = "YOUR_ANON_KEY"
