# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Your Supabase project URL (from apps/web/.env.local → SUPABASE_URL)
SUPABASE_URL=

# Supabase anon (public) key (from apps/web/.env.local → SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=

# Optional: web app URL opened when the user presses [s] to sign up.
# Defaults to SUPABASE_URL if not set.
# KERN_WEB_URL=https://app.kern.so
