{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kern",
  "version": "0.1.0",
  "identifier": "com.kern.app",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm --filter web dev",
    "beforeBuildCommand": "cd ../.. && pnpm --filter web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "kern",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "macOS": {
      "bundleName": "kern"
    },
    "active": true,
    "publisher": "Kern",
    "copyright": "Copyright © Kern",
    "shortDescription": "Kern",
    "longDescription": "Kern — personal data operating system.",
    "targets": ["dmg", "nsis", "msi", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
