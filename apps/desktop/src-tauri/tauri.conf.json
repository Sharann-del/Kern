{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kern",
  "version": "0.1.0",
  "identifier": "com.kern.app",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm --filter web dev",
    "beforeBuildCommand": "cd ../.. && pnpm --filter web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kern",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "msi", "deb", "appimage"],
    "icon": ["icons/icon.png"]
  }
}
